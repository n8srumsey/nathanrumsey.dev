---
interface Props {
  size?: number;
}
const { size = 16 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class="shrink-0"
>
  <polyline points="9 18 15 12 9 6"></polyline>
</svg>
