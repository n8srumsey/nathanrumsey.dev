---
import { FAVICON_VIEWBOX, faviconShapes, faviconStyles } from '../../utils/favicon.ts';

interface Props {
  size?: number;
}
const { size = 20 } = Astro.props;

const shapes = faviconShapes();
const styles = faviconStyles();
---

<svg
  width={size}
  height={size}
  viewBox={FAVICON_VIEWBOX}
  aria-hidden="true"
  class="inline-block align-middle shrink-0 translate-y-1"
>
  <style set:html={styles} />
  
  <Fragment set:html={shapes} />
</svg>
