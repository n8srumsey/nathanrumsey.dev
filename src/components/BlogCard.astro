---
import type { CollectionEntry } from 'astro:content';
import { readingTime } from '../utils/readingTime';
import { idToSlug } from '../utils/slugs';
import Card from './Card.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  seriesLabel?: string;
  seriesSlug?: string;
}

const { post, seriesLabel, seriesSlug } = Astro.props;
---

<Card>
  <div class="flex items-start gap-4">
    <a href={`/blog/${idToSlug(post.id)}`} class="group block flex-1 min-w-0">
      <h2 class="font-semibold group-hover:underline">{post.data.title}</h2>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 font-mono text-sm text-muted-foreground mt-1">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span aria-hidden="true">·</span>
        <span>{readingTime(post.body ?? '')} min read</span>
        {post.data.tags.length > 0 && <span aria-hidden="true">·</span>}
        {post.data.tags.map(tag => (
          <span class="text-xs px-2 py-0.5 bg-surface rounded-full shadow-sm">{tag}</span>
        ))}
      </div>
      <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{post.data.description}</p>
    </a>
    {seriesLabel && seriesSlug && (
      <a
        href={`/blog/series/${seriesSlug}`}
        class="font-mono text-xs text-muted-foreground hover:text-primary transition-colors shrink-0 text-right"
      >
        {seriesLabel}
      </a>
    )}
  </div>
</Card>
