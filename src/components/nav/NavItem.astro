---
interface Props {
  href: string;
  active?: boolean;
}

const { href, active = false } = Astro.props;
---

<a
  href={href}
  class={`px-3 py-1.5 rounded-full transition-colors duration-150 ${active ? 'text-foreground bg-primary-subtle' : 'text-muted-foreground hover:text-foreground hover:bg-primary-subtle'}`}
  aria-current={active ? 'page' : undefined}
>
  <slot />
</a>
