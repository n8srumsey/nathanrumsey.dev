---
import GitHubIcon from "../icons/GitHubIcon.astro"
import LinkedInIcon from "../icons/LinkedInIcon.astro"
import DownloadIcon from "../icons/DownloadIcon.astro"
import GlobeIcon from "../icons/GlobeIcon"
import MailIcon from "../icons/MailIcon"
import IconLink from "../ui/IconLink"

interface Props {
    metadata: HeadingData
}

const { metadata } = Astro.props
---

<div>
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">{metadata.name}</h1>
        <div class="flex items-center gap-3">
            {metadata.social?.github && (
                <a href={metadata.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-muted-foreground hover:text-primary transition-colors">
                    <GitHubIcon size={18} />
                </a>
            )}
            {metadata.social?.linkedin && (
                <a href={metadata.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-muted-foreground hover:text-primary transition-colors">
                    <LinkedInIcon size={18} />
                </a>
            )}
            <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" aria-label="View PDF resume" class="text-muted-foreground hover:text-primary transition-colors">
                <DownloadIcon size={18} />
            </a>
        </div>
    </div>

    <div class="flex items-start justify-between gap-8 mt-1">
        <div class="space-y-1">
            <p class="text-muted-foreground">{metadata.title}</p>
            {metadata.location && (<p class="font-mono text-sm text-muted-foreground">{metadata.location}</p>)}
        </div>
        <div class="font-mono text-sm space-y-1 shrink-0 text-muted-foreground">
            {metadata.email && (
                <div class="flex justify-end">
                    <IconLink href={`mailto:${metadata.email}`} Icon={MailIcon} iconSize={14} label={metadata.email} />
                </div>
            )}
            {metadata.website && (
                <div class="flex justify-end">
                    <IconLink href={metadata.website} Icon={GlobeIcon} iconSize={14} label={metadata.website.replace(/^https?:\/\//, "")} external />
                </div>
            )}
        </div>
    </div>
</div>

{metadata.summary && (<p class="mt-4 leading-relaxed text-foreground"> {metadata.summary} </p>)}
