---
import { formatDate } from '../../../utils/dates';
import ResumeList from '../../ui/ResumeList.astro';
import AnnotatedText from '../../ui/AnnotatedText';

interface Props {
    experience: ExperienceData
}
const { experience } = Astro.props;
---

<div>
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5 sm:gap-4">
        <h3 class="font-medium">{experience.role}</h3>
        <span class="font-mono text-sm text-muted-foreground sm:shrink-0">
        {formatDate(experience.start)} {'\u2014'}{" "}
        {experience.end ? formatDate(experience.end) : "Present"}
        </span>
    </div>

    <div class="flex justify-between">
        <p class="text-sm text-muted-foreground mt-0.5"> {experience.company} </p>
        {experience.location && <p class="text-sm text-muted-foreground mt-0.5"> {experience.location} </p>}
    </div>

    <AnnotatedText
      client:visible
      description={experience.description}
      annotations={experience.annotations}
      className="mt-2 text-sm leading-relaxed text-foreground"
    />

    {experience.highlights.length > 0 && (
        <ResumeList>
            {experience.highlights.map((h) => (
                <li>
                    <AnnotatedText
                      client:visible
                      description={h}
                      annotations={experience.annotations}
                    />
                </li>
            ))}
        </ResumeList>
    )}
</div>