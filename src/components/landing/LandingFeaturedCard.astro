---
import ChevronRightIcon from '../icons/ChevronRightIcon.astro'
interface Props {
    callout: string,
    title: string,
    contentUrl: string,
    description: string,
    moreText: string,
    moreLink: string,
}
const { callout, title, contentUrl, description, moreText, moreLink } = Astro.props
---
<div class="border border-border rounded-lg p-5 bg-surface flex flex-col gap-3 group hover:border-primary/40 transition-colors">
    <span class="font-mono text-xs text-primary tracking-wider uppercase">{callout}</span>

    <div>
        <a href={contentUrl} class="font-semibold hover:text-primary hover:underline transition-colors">
            {title}
        </a>
        <p class="text-sm text-muted-foreground mt-1 line-clamp-2">{description}</p>
    </div>
    <a href={moreLink} class="flex items-center gap-0.5 font-mono text-xs text-muted-foreground group-hover:text-primary group-hover:font-medium transition-colors mt-auto self-end">
        {moreText}
        <ChevronRightIcon />
    </a>
</div>
