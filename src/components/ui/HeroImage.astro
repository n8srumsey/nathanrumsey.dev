---
import MarkdownString from './MarkdownString.astro';

interface Props {
  src: string;
  alt?: string;
  caption?: string;
}

const { src, alt = '', caption } = Astro.props;
---

<figure class="my-8">
  <img src={src} alt={alt} class="w-full rounded-lg aspect-video object-cover" />
  {caption && (
    <figcaption class="mt-2 text-sm text-muted-foreground font-mono text-center">
      <MarkdownString content={caption} />
    </figcaption>
  )}
</figure>
