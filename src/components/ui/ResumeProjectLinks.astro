---
import GitHubIcon from '../icons/GitHubIcon'
import GlobeIcon from '../icons/GlobeIcon'
import ProjectIcon from '../icons/ProjectIcon'
import IconLink from './IconLink'
interface Props {
    hasDetailPage: boolean,
    liveUrl?: string | undefined,
    repoUrl?: string | undefined,
    slug?: string
}
const { hasDetailPage, liveUrl, repoUrl, slug } = Astro.props
---


{(hasDetailPage || liveUrl || repoUrl) && (
    <div class="flex flex-wrap gap-x-4 gap-y-1 font-mono text-sm text-muted-foreground mt-0.5 shrink-0">
        {repoUrl && ( <IconLink href={repoUrl} Icon={GitHubIcon} iconSize={14} label="Source Code" external/>)}
        {liveUrl && ( <IconLink href={liveUrl} Icon={GlobeIcon} iconSize={14} label="Live Website" external/>)}
        {hasDetailPage && ( <IconLink href={`/projects/${slug}`} Icon={ProjectIcon} iconSize={14} label="More Details"/>)}
    </div>
)}