---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import SeriesIcon from '../../components/icons/SeriesIcon.astro';
import ChevronLeftIcon from '../../components/icons/ChevronLeftIcon.astro';
import ChevronRightIcon from '../../components/icons/ChevronRightIcon.astro';
import TagLink from '../../components/ui/TagLink.astro';
import MdxImage from '../../components/ui/MdxImage.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import { idToSlug } from '../../utils/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: idToSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const mins = readingTime(post.body ?? '');

const allSeries = await getCollection('series');
let seriesEntry = null;
if (post.data.series) {
  const found = allSeries.find(s => idToSlug(s.id) === post.data.series);
  if (!found) throw new Error(`Post "${post.id}" references series "${post.data.series}" which does not exist.`);
  seriesEntry = found;
}

const postSlug = idToSlug(post.id);
const seriesIndex = seriesEntry ? seriesEntry.data.posts.indexOf(postSlug) : -1;
const prevSlug = seriesEntry && seriesIndex > 0
  ? seriesEntry.data.posts[seriesIndex - 1]
  : null;
const nextSlug = seriesEntry && seriesIndex < (seriesEntry.data.posts.length - 1)
  ? seriesEntry.data.posts[seriesIndex + 1]
  : null;
const seriesSlug = seriesEntry ? idToSlug(seriesEntry.id) : null;

const seriesLabel = seriesEntry?.data.name ?? null;
const seriesPosition = seriesEntry ? seriesIndex + 1 : null;

// Adjacent post data for prev/next nav
const allPosts = seriesEntry ? await getCollection('blog', ({ data }) => !data.draft) : [];
const prevPost = prevSlug ? (allPosts.find(p => idToSlug(p.id) === prevSlug) ?? null) : null;
const nextPost = nextSlug ? (allPosts.find(p => idToSlug(p.id) === nextSlug) ?? null) : null;
const prevSeriesPosition = prevSlug ? seriesIndex : null;      // prev is at (seriesIndex-1)+1 = seriesIndex
const nextSeriesPosition = nextSlug ? seriesIndex + 2 : null;  // next is at (seriesIndex+1)+1 = seriesIndex+2

const crumbs = [
  { label: 'Blog', href: '/blog' },
  ...(seriesEntry && seriesSlug && seriesLabel
    ? [{ label: seriesLabel, href: `/blog/series/${seriesSlug}`, icon: 'series' as const, truncate: true }]
    : []),
  {
    label: seriesEntry && seriesPosition
      ? `Part ${seriesPosition} · ${post.data.title}`
      : post.data.title,
    truncate: !!seriesEntry,
  },
];
---

<BaseLayout title={`${post.data.title} — Nathan Rumsey`} description={post.data.description}>
  <article>
    <Breadcrumb crumbs={crumbs} />
    <header class="pb-8 mb-8 border-b border-border">
      <h1 class="text-2xl font-bold leading-snug">{post.data.title}</h1>
      <div class="flex gap-3 font-mono text-sm text-muted-foreground mt-2">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{mins} min read</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {post.data.tags.map(tag => (
            <TagLink tag={tag} href={`/blog?tag=${encodeURIComponent(tag)}`} />
          ))}
        </div>
      )}
      {seriesEntry && seriesSlug && seriesPosition && (
        <div class="flex items-center gap-1.5 font-mono text-sm text-muted-foreground mt-3">
          <span>Part {seriesPosition} of</span>
          <a href={`/blog/series/${seriesSlug}`} class="hover:text-primary transition-colors flex items-center gap-1">
            <SeriesIcon />
            {seriesEntry.data.name}
          </a>
        </div>
      )}
    </header>

    {post.data.heroImage && (
      <figure class="my-8">
        <img
          src={post.data.heroImage}
          alt={post.data.imageCaption ?? ''}
          class="w-full rounded-lg aspect-video object-cover"
        />
        {post.data.imageCaption && (
          <figcaption class="mt-2 text-sm text-muted-foreground font-mono text-center">
            {post.data.imageCaption}
          </figcaption>
        )}
      </figure>
    )}

    <div class="prose prose-invert max-w-none">
      <Content components={{ img: MdxImage }} />
    </div>

    {seriesEntry && (
      <nav class="mt-12 pt-6 border-t border-border" aria-label="Series navigation">
        <div class="flex justify-between gap-4 font-mono text-sm">
          <div class="flex-1">
            {prevPost && (
              <a href={`/blog/${prevSlug}`} class="group flex flex-col gap-1 text-muted-foreground hover:text-primary transition-colors max-w-[14rem]">
                <span class="flex items-center gap-1.5">
                  <ChevronLeftIcon />
                  Previous
                </span>
                <span class="text-xs pl-[22px] leading-snug">
                  {prevSeriesPosition != null ? `Part ${prevSeriesPosition} · ` : ''}{prevPost.data.title}
                </span>
              </a>
            )}
          </div>
          <div class="flex-1 flex justify-end">
            {nextPost && (
              <a href={`/blog/${nextSlug}`} class="group flex flex-col gap-1 text-muted-foreground hover:text-primary transition-colors items-end max-w-[14rem]">
                <span class="flex items-center gap-1.5">
                  Next
                  <ChevronRightIcon />
                </span>
                <span class="text-xs pr-[22px] leading-snug text-right">
                  {nextSeriesPosition != null ? `Part ${nextSeriesPosition} · ` : ''}{nextPost.data.title}
                </span>
              </a>
            )}
          </div>
        </div>
      </nav>
    )}
  </article>
</BaseLayout>
