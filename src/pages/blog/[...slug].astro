---
import DocumentLayout from '../../layouts/DocumentLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import SeriesIcon from '../../components/icons/SeriesIcon.astro';
import TagLink from '../../components/ui/TagLink.astro';
import MdxImage from '../../components/ui/MdxImage.astro';
import MdxTable from '../../components/ui/MdxTable';
import IconLink from '../../components/ui/IconLink';
import ProjectIcon from '../../components/icons/ProjectIcon';
import HeroImage from '../../components/ui/HeroImage.astro';
import SeriesNav from '../../components/blog/SeriesNav.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import { idToSlug } from '../../utils/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: idToSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const mins = readingTime(post.body ?? '');

const allSeries = await getCollection('series');
let seriesEntry = null;
if (post.data.series) {
  const found = allSeries.find(s => idToSlug(s.id) === post.data.series);
  if (!found) throw new Error(`Post "${post.id}" references series "${post.data.series}" which does not exist.`);
  seriesEntry = found;
}

const postSlug = idToSlug(post.id);

const allProjects = await getCollection('projects');
const relatedProjects = allProjects.filter(p => p.data.relatedPosts.includes(postSlug));
const seriesIndex = seriesEntry ? seriesEntry.data.posts.indexOf(postSlug) : -1;
const prevSlug = seriesEntry && seriesIndex > 0
  ? seriesEntry.data.posts[seriesIndex - 1]
  : null;
const nextSlug = seriesEntry && seriesIndex < (seriesEntry.data.posts.length - 1)
  ? seriesEntry.data.posts[seriesIndex + 1]
  : null;
const seriesSlug = seriesEntry ? idToSlug(seriesEntry.id) : null;

const seriesLabel = seriesEntry?.data.name ?? null;
const seriesPosition = seriesEntry ? seriesIndex + 1 : null;

// Adjacent post data for prev/next nav
const allPosts = seriesEntry ? await getCollection('blog', ({ data }) => !data.draft) : [];
const prevPost = prevSlug ? (allPosts.find(p => idToSlug(p.id) === prevSlug) ?? null) : null;
const nextPost = nextSlug ? (allPosts.find(p => idToSlug(p.id) === nextSlug) ?? null) : null;
const prevSeriesPosition = prevSlug ? seriesIndex : null;      // prev is at (seriesIndex-1)+1 = seriesIndex
const nextSeriesPosition = nextSlug ? seriesIndex + 2 : null;  // next is at (seriesIndex+1)+1 = seriesIndex+2

const crumbs = [
  { label: 'Blog', href: '/blog' },
  ...(seriesEntry && seriesSlug && seriesLabel
    ? [{ label: seriesLabel, href: `/blog/series/${seriesSlug}`, icon: 'series' as const, truncate: true }]
    : []),
  { label: post.data.title, truncate: !!seriesEntry },
];
---

<DocumentLayout title={`${post.data.title} \u2014 Nathan Rumsey`} description={post.data.description} image={post.data.heroImage} type="article">
  <article>
    <Breadcrumb crumbs={crumbs} />
    <header class="pb-8 mb-8 border-b border-border">
      <h1 class="text-2xl font-bold leading-snug">{post.data.title}</h1>
      <div class="flex gap-3 font-mono text-sm text-muted-foreground mt-2">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>{'\u00B7'}</span>
        <span>{mins} min read</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {post.data.tags.map(tag => (
            <TagLink tag={tag} href={`/blog?tag=${encodeURIComponent(tag)}`} />
          ))}
        </div>
      )}
      {seriesEntry && seriesSlug && seriesPosition && (
        <div class="flex items-center flex-wrap gap-x-1.5 gap-y-1 font-mono text-sm text-muted-foreground mt-3">
          <span>Part {seriesPosition} of</span>
          <a href={`/blog/series/${seriesSlug}`} class="hover:text-primary transition-colors flex items-center gap-1">
            <SeriesIcon />
            {seriesEntry.data.name}
          </a>
          {relatedProjects.length > 0 && (
            <>
              <span>{'\u00B7'}</span>
              {relatedProjects.map(project => (
                <IconLink
                  href={`/projects/${idToSlug(project.id)}`}
                  Icon={ProjectIcon}
                  label={project.data.name}
                />
              ))}
            </>
          )}
        </div>
      )}
      {!seriesEntry && relatedProjects.length > 0 && (
        <div class="flex flex-wrap gap-x-3 gap-y-1 mt-3 font-mono text-sm text-muted-foreground">
          {relatedProjects.map(project => (
            <IconLink
              href={`/projects/${idToSlug(project.id)}`}
              Icon={ProjectIcon}
              label={project.data.name}
            />
          ))}
        </div>
      )}
    </header>

    {post.data.heroImage && (
      <HeroImage src={post.data.heroImage} alt={post.data.imageCaption ?? ''} caption={post.data.imageCaption} />
    )}

    <div class="prose prose-invert max-w-none">
      <Content components={{ img: MdxImage, table: MdxTable }} />
    </div>

    {seriesEntry && (
      <SeriesNav
        prevSlug={prevSlug}
        prevTitle={prevPost?.data.title ?? null}
        prevPosition={prevSeriesPosition}
        nextSlug={nextSlug}
        nextTitle={nextPost?.data.title ?? null}
        nextPosition={nextSeriesPosition}
      />
    )}
  </article>
</DocumentLayout>
