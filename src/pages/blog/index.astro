---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogIndexFilter from '../../components/blog/BlogIndexFilter';
import type { BlogPostData } from '../../components/blog/BlogIndexFilter';
import { getCollection } from 'astro:content';
import { idToSlug } from '../../utils/slugs';
import { readingTime } from '../../utils/readingTime';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allSeries = await getCollection('series');
const seriesById = new Map(
  allSeries.map(s => [idToSlug(s.id), { name: s.data.name, slug: idToSlug(s.id), posts: s.data.posts }])
);
for (const post of posts) {
  if (post.data.series && !seriesById.has(post.data.series)) {
    throw new Error(`Post "${post.id}" references series "${post.data.series}" which does not exist.`);
  }
}

function getSeriesProps(post: (typeof posts)[number]) {
  if (!post.data.series) return {};
  const info = seriesById.get(post.data.series);
  if (!info) return {};
  const pos = info.posts.indexOf(idToSlug(post.id));
  return {
    series: post.data.series,
    seriesLabel: info.name,
    seriesSlug: info.slug,
    seriesPosition: pos >= 0 ? pos + 1 : undefined,
  };
}

const postData: BlogPostData[] = posts.map(post => ({
  slug: idToSlug(post.id),
  title: post.data.title,
  date: post.data.date.toISOString(),
  description: post.data.description,
  tags: post.data.tags,
  readingMinutes: readingTime(post.body ?? ''),
  image: post.data.heroImage,
  ...getSeriesProps(post),
}));
---

<BaseLayout title="Blog — Nathan Rumsey" description="Dev diaries and essays on technology.">
  <h1 class="text-2xl font-bold mb-4">Blog</h1>
  <BlogIndexFilter posts={postData} client:load />
</BaseLayout>
