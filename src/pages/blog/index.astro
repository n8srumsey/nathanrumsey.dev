---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import { idToSlug } from '../../utils/slugs';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog — Nathan Rumsey" description="Dev diaries and essays on technology.">
  <h1 class="text-2xl font-bold mb-8">Blog</h1>
  {posts.length === 0 && <p class="text-gray-500">No posts yet.</p>}
  <div class="space-y-10">
    {posts.map(post => (
      <article>
        <a href={`/blog/${idToSlug(post.id)}`} class="group block">
          <h2 class="font-semibold group-hover:underline">{post.data.title}</h2>
          <div class="flex gap-3 text-sm text-gray-500 mt-1">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span>·</span>
            <span>{readingTime(post.body ?? '')} min read</span>
          </div>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {post.data.tags.map(tag => (
                <span class="text-xs px-2 py-0.5 bg-gray-100 rounded-full text-gray-600">{tag}</span>
              ))}
            </div>
          )}
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
