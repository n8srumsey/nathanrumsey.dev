---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nathan Rumsey">
  <section class="py-8">
    <h1 class="text-3xl font-bold tracking-tight">Nathan Rumsey</h1>
    <p class="text-lg text-gray-600 mt-2">Software Engineer</p>
    <p class="mt-6 text-gray-700 max-w-prose leading-relaxed">
      I build software. This is my portfolio, resume, and a place for writing about things I find worth writing about.
    </p>
    <div class="mt-8 flex gap-6 text-sm">
      <a href="/resume" class="font-medium underline underline-offset-4">Resume</a>
      <a href="/blog" class="font-medium underline underline-offset-4">Blog</a>
      <a href="/projects" class="font-medium underline underline-offset-4">Projects</a>
    </div>
  </section>
</BaseLayout>
