---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { idToSlug } from '../utils/slugs';
import LandingFeaturedCard from '../components/landing/LandingFeaturedCard.astro';

const resumeEntries = await getCollection('resume');
const basics = resumeEntries[0]?.data.basics;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPost = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

const allProjects = await getCollection('projects');
const pinnedProject = allProjects.find(p => p.data.homepagePin);
const featuredProject = pinnedProject ?? allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (b.data.start ?? '').localeCompare(a.data.start ?? ''))[0];
---

<BaseLayout title="Nathan Rumsey">
  <!-- Viewport-height hero: name, title, section links centered -->
  <section class="flex-1 flex flex-col items-center justify-center px-6 py-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight">{basics?.name ?? 'Nathan Rumsey'}</h1>
    <p class="text-lg text-muted-foreground mt-2">{basics?.title ?? 'Software Engineer'}</p>
    <nav class="mt-8 flex flex-wrap gap-6 justify-center text-sm" aria-label="Site sections">
      <a href="/about" class="text-muted-foreground hover:text-primary transition-colors">About</a>
      <a href="/resume" class="text-muted-foreground hover:text-primary transition-colors">Resume</a>
      <a href="/projects" class="text-muted-foreground hover:text-primary transition-colors">Projects</a>
      <a href="/blog" class="text-muted-foreground hover:text-primary transition-colors">Blog</a>
    </nav>
  </section>

  <!-- Below-fold callout cards -->
  {(latestPost || featuredProject) && (
    <section class="pb-16 px-6">
      <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-4">
        {latestPost && (
          <LandingFeaturedCard 
              callout='Latest Post' 
              title={latestPost.data.title} 
              contentUrl={`/blog/${idToSlug(latestPost.id)}`} 
              description={latestPost.data.description} 
              moreText='All posts'
              moreLink='/blog'/>
        )}
        {featuredProject && (
          <LandingFeaturedCard 
              callout='Featured Project' 
              title={featuredProject.data.name} 
              contentUrl={`/projects/${idToSlug(featuredProject.id)}`} 
              description={featuredProject.data.description} 
              moreText='All projects' 
              moreLink='/projects'/>
        )}
      </div>
    </section>
  )}
</BaseLayout>
