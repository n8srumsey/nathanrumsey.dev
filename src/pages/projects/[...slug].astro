---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import GitHubIcon from '../../components/icons/GitHubIcon';
import GlobeIcon from '../../components/icons/GlobeIcon';
import LayersIcon from '../../components/icons/LayersIcon';
import ArticleIcon from '../../components/icons/ArticleIcon';
import IconLink from '../../components/ui/IconLink';
import TagLink from '../../components/ui/TagLink.astro';
import MdxImage from '../../components/ui/MdxImage.astro';
import { getCollection, render } from 'astro:content';
import { idToSlug } from '../../utils/slugs';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: idToSlug(project.id) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const hasBody = (project.body?.trim().length ?? 0) > 0;

const allSeries = await getCollection('series');
const seriesEntry = project.data.relatedSeries
  ? allSeries.find(s => idToSlug(s.id) === project.data.relatedSeries) ?? null
  : null;

const allPosts = project.data.relatedPosts.length > 0
  ? await getCollection('blog', ({ data }) => !data.draft)
  : [];
const relatedPostEntries = project.data.relatedPosts
  .map(slug => allPosts.find(p => idToSlug(p.id) === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);
---

<BaseLayout title={`${project.data.name} — Nathan Rumsey`} description={project.data.description} image={project.data.image}>
  <article>
    <Breadcrumb crumbs={[
      { label: 'Projects', href: '/projects' },
      { label: project.data.name },
    ]} />
    <header class="mb-8">
      <h1 class="text-2xl font-bold font-mono">{project.data.name}</h1>
      <p class="text-muted-foreground mt-1">{project.data.description}</p>

      {project.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {project.data.tags.map(tag => (
            <TagLink tag={tag} href={`/projects?tag=${encodeURIComponent(tag)}`} />
          ))}
        </div>
      )}

      {(project.data.repoUrl || project.data.liveUrl || seriesEntry || relatedPostEntries.length > 0) && (
        <div class="flex flex-wrap gap-x-4 gap-y-1.5 mt-4 font-mono text-sm text-muted-foreground">
          {project.data.repoUrl && (
            <IconLink href={project.data.repoUrl} Icon={GitHubIcon} iconSize={14} label="Source Code" external />
          )}
          {project.data.liveUrl && (
            <IconLink href={project.data.liveUrl} Icon={GlobeIcon} iconSize={14} label="Live Website" external />
          )}
          {seriesEntry && (
            <IconLink href={`/blog/series/${idToSlug(seriesEntry.id)}`} Icon={LayersIcon} iconSize={14} label={seriesEntry.data.name} />
          )}
          {relatedPostEntries.map(post => (
            <IconLink href={`/blog/${idToSlug(post.id)}`} Icon={ArticleIcon} iconSize={14} label={post.data.title} />
          ))}
        </div>
      )}
    </header>

    {project.data.image && (
      <figure class="my-8">
        <img
          src={project.data.image}
          alt={project.data.imageCaption ?? ''}
          class="w-full rounded-lg aspect-video object-cover"
        />
        {project.data.imageCaption && (
          <figcaption class="mt-2 text-sm text-muted-foreground font-mono text-center">
            {project.data.imageCaption}
          </figcaption>
        )}
      </figure>
    )}

    {hasBody && (
      <div class="prose prose-invert max-w-none">
        <Content components={{ img: MdxImage }} />
      </div>
    )}
  </article>
</BaseLayout>
