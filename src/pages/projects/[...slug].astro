---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SeriesIcon from '../../components/SeriesIcon.astro';
import { getCollection, render } from 'astro:content';
import { idToSlug } from '../../utils/slugs';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: idToSlug(project.id) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const hasBody = (project.body?.trim().length ?? 0) > 0;

const allSeries = await getCollection('series');
const seriesEntry = project.data.relatedSeries
  ? allSeries.find(s => idToSlug(s.id) === project.data.relatedSeries) ?? null
  : null;

const allPosts = project.data.relatedPosts.length > 0
  ? await getCollection('blog', ({ data }) => !data.draft)
  : [];
const relatedPostEntries = project.data.relatedPosts
  .map(slug => allPosts.find(p => idToSlug(p.id) === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);
---

<BaseLayout title={`${project.data.name} — Nathan Rumsey`} description={project.data.description}>
  <article>
    <Breadcrumb crumbs={[
      { label: 'Projects', href: '/projects' },
      { label: project.data.name },
    ]} />
    <header class="mb-8">
      <h1 class="text-2xl font-bold font-mono">{project.data.name}</h1>
      <p class="text-muted-foreground mt-1">{project.data.description}</p>

      {project.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {project.data.tags.map(tag => (
            <span class="font-mono text-xs px-2 py-0.5 bg-surface-raised rounded-full text-muted-foreground shadow-sm">{tag}</span>
          ))}
        </div>
      )}

      <div class="flex gap-4 mt-4 text-sm font-mono">
        {project.data.repoUrl && (
          <a
            href={project.data.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary hover:text-primary/80 transition-colors underline underline-offset-4"
          >
            Source code
          </a>
        )}
        {project.data.liveUrl && (
          <a
            href={project.data.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary hover:text-primary/80 transition-colors underline underline-offset-4"
          >
            Live site
          </a>
        )}
      </div>

      {(seriesEntry || relatedPostEntries.length > 0) && (
        <div class="flex flex-wrap gap-x-4 gap-y-1.5 mt-4 font-mono text-sm text-muted-foreground">
          {seriesEntry && (
            <a
              href={`/blog/series/${idToSlug(seriesEntry.id)}`}
              class="flex items-center gap-1 hover:text-primary transition-colors"
            >
              <SeriesIcon />
              {seriesEntry.data.name}
            </a>
          )}
          {relatedPostEntries.map(post => (
            <a
              href={`/blog/${idToSlug(post.id)}`}
              class="hover:text-primary transition-colors underline underline-offset-2"
            >
              {post.data.title}
            </a>
          ))}
        </div>
      )}
    </header>

    {hasBody && (
      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>
