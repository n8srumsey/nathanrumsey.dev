---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { idToSlug } from '../../utils/slugs';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.name.localeCompare(b.data.name);
});

function hasDetailPage(project: CollectionEntry<'projects'>): boolean {
  return (
    (project.body?.trim().length ?? 0) > 0 ||
    !!project.data.relatedSeries ||
    project.data.relatedPosts.length > 0
  );
}

function projectHref(project: CollectionEntry<'projects'>): string {
  if (hasDetailPage(project)) return `/projects/${idToSlug(project.id)}`;
  return project.data.liveUrl ?? project.data.repoUrl ?? '#';
}
---

<BaseLayout title="Projects — Nathan Rumsey" description="A catalog of projects I've built.">
  <h1 class="text-2xl font-bold mb-8">Projects</h1>
  <div class="space-y-4">
    {projects.map(project => {
      const detail = hasDetailPage(project);
      const href = projectHref(project);
      return (
        <article class="border border-gray-100 rounded-lg p-5 hover:border-gray-300 transition-colors">
          <a
            href={href}
            class="block"
            target={detail ? undefined : '_blank'}
            rel={detail ? undefined : 'noopener noreferrer'}
          >
            <div class="flex items-start justify-between gap-4">
              <h2 class="font-semibold font-mono text-sm">{project.data.name}</h2>
              {project.data.featured && (
                <span class="text-xs text-gray-400 shrink-0">featured</span>
              )}
            </div>
            <p class="text-sm text-gray-600 mt-1 leading-relaxed">{project.data.description}</p>
            {project.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {project.data.tags.map(tag => (
                  <span class="text-xs px-2 py-0.5 bg-gray-100 rounded-full text-gray-600">{tag}</span>
                ))}
              </div>
            )}
            <div class="flex gap-3 mt-3 text-xs text-gray-400">
              {project.data.repoUrl && <span>Source</span>}
              {project.data.liveUrl && <span>Live</span>}
              {detail && <span>Detail →</span>}
            </div>
          </a>
        </article>
      );
    })}
  </div>
</BaseLayout>
