---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectIndexFilter from '../../components/projects/ProjectIndexFilter';
import type { ProjectData } from '../../components/projects/ProjectIndexFilter';
import { getCollection } from 'astro:content';
import { idToSlug } from '../../utils/slugs';

const projects = await getCollection('projects');
const allSeries = await getCollection('series');
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const projectData: ProjectData[] = projects.map(project => {
  const hasDetailPage =
    (project.body?.trim().length ?? 0) > 0 ||
    !!project.data.relatedSeries ||
    project.data.relatedPosts.length > 0;

  const seriesEntry = project.data.relatedSeries
    ? allSeries.find(s => idToSlug(s.id) === project.data.relatedSeries) ?? null
    : null;

  const relatedPostEntries = project.data.relatedPosts
    .map(slug => allPosts.find(p => idToSlug(p.id) === slug))
    .filter((p): p is NonNullable<typeof p> => p !== undefined);

  return {
    slug: idToSlug(project.id),
    name: project.data.name,
    description: project.data.description,
    tags: project.data.tags,
    featured: project.data.featured,
    repoUrl: project.data.repoUrl,
    liveUrl: project.data.liveUrl,
    hasDetailPage,
    relatedSeries: seriesEntry
      ? { slug: idToSlug(seriesEntry.id), name: seriesEntry.data.name }
      : undefined,
    relatedPosts: relatedPostEntries.map(p => ({ slug: idToSlug(p.id), title: p.data.title })),
    image: project.data.image,
    start: project.data.start,
    end: project.data.end,
  };
});
---

<BaseLayout title="Projects — Nathan Rumsey" description="A catalog of projects I've built.">
  <h1 class="text-2xl font-bold mb-4">Projects</h1>
  <ProjectIndexFilter projects={projectData} client:load />
</BaseLayout>
