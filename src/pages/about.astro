---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getCollection } from 'astro:content';

const resumeEntries = await getCollection('resume');
const basics = resumeEntries[0]?.data.basics;
---

<BaseLayout title={"About \u2014 Nathan Rumsey"}>
  <article class="max-w-2xl w-full mx-auto px-8 py-10 my-8">
    <h1 class="text-3xl font-bold tracking-tight">{basics?.name ?? 'Nathan Rumsey'}</h1>
    <p class="text-lg text-muted-foreground mt-1">{basics?.title ?? 'Software Engineer'}</p>

    {basics?.summary && (
      <p class="mt-6 text-muted-foreground leading-relaxed max-w-prose">
        {basics.summary}
      </p>
    )}

    <div class="mt-8 flex flex-wrap gap-5 text-sm">
      <SocialLinks email={basics?.email} github={basics?.social?.github} linkedin={basics?.social?.linkedin} />
    </div>
  </article>
</BaseLayout>
