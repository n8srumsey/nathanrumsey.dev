---
import DocumentLayout from "../layouts/DocumentLayout.astro";
import { getCollection } from "astro:content";
import { chain, parseDate } from "../utils/projectFilters";
import SkillsSection from "../components/resume/SkillsSection.astro";
import ProjectsSection from "../components/resume/ProjectsSection.astro";
import EducationSection from "../components/resume/EducationSection.astro";
import ExperienceSection from "../components/resume/ExperienceSection.astro";
import HeadingSection from "../components/resume/HeadingSection.astro";

const resumeEntries = await getCollection("resume");
const resumeEntry = resumeEntries[0];
if (!resumeEntry) throw new Error("src/content/resume/main.yaml not found");
const resume = resumeEntry.data;

const toMs = (v: string | undefined): number => parseDate(v) ?? -Infinity;

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort(
    chain(
      (a, b) => (b.data.resumeDisplayPriority ?? -Infinity) - (a.data.resumeDisplayPriority ?? -Infinity),
      (a, b) => toMs(b.data.start) - toMs(a.data.start),
      (a, b) => toMs(b.data.end) - toMs(a.data.end),
      (a, b) => a.data.name.localeCompare(b.data.name),
    )
  );
---

<DocumentLayout title={`Resume \u2014 ${resume.basics.name}`} description="Professional resume">
  <HeadingSection metadata={resume.basics}/>
  <ExperienceSection experience={resume.experience} />
  <EducationSection education={resume.education} />
  <ProjectsSection projects={featuredProjects} />
  <SkillsSection skills={resume.skills.categories} />
</DocumentLayout>
