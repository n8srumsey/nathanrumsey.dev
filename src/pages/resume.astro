---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { idToSlug } from '../utils/slugs';
import IconLink from '../components/ui/IconLink';
import GitHubIcon from '../components/icons/GitHubIcon';
import GlobeIcon from '../components/icons/GlobeIcon';
import ProjectIcon from '../components/icons/ProjectIcon';

const resumeEntries = await getCollection('resume');
const resumeEntry = resumeEntries[0];
if (!resumeEntry) throw new Error('src/content/resume/main.yaml not found');
const resume = resumeEntry.data;

const featuredProjects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => {
    if (!a.data.start && !b.data.start) return 0;
    if (!a.data.start) return 1;
    if (!b.data.start) return -1;
    return b.data.start.localeCompare(a.data.start);
  });

function formatDate(ym: string): string {
  const [year, month] = ym.split('-');
  return new Date(Number(year), Number(month) - 1).toLocaleDateString('en-US', {
    month: 'short',
    year: 'numeric',
  });
}
---

<BaseLayout title={`Resume — ${resume.basics.name}`} description="Professional resume">
  <div>
    <h1 class="text-2xl font-bold">{resume.basics.name}</h1>
    <div class="flex items-start justify-between gap-8 mt-1">
      <div class="space-y-1">
        <p class="text-muted-foreground">{resume.basics.title}</p>
        {resume.basics.location && (
          <p class="font-mono text-sm text-muted-foreground">{resume.basics.location}</p>
        )}
      </div>
      <div class="text-right font-mono text-sm space-y-1 shrink-0">
        {resume.basics.email && (
          <div>
            <a href={`mailto:${resume.basics.email}`} class="text-muted-foreground hover:text-primary transition-colors">
              {resume.basics.email}
            </a>
          </div>
        )}
        {resume.basics.website && (
          <div>
            <a href={resume.basics.website} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
              {resume.basics.website.replace(/^https?:\/\//, '')}
            </a>
          </div>
        )}
      </div>
    </div>
  </div>

  {resume.basics.summary && (
    <p class="mt-4 leading-relaxed text-muted-foreground">{resume.basics.summary}</p>
  )}

  <section class="mt-10">
    <h2 class="text-base font-semibold uppercase tracking-wide text-muted-foreground border-b border-border pb-1 mb-5">
      Experience
    </h2>
    <div class="space-y-8">
      {resume.experience.map(exp => (
        <div>
          <div class="flex justify-between items-baseline gap-4">
            <h3 class="font-medium">{exp.role}</h3>
            <span class="font-mono text-sm text-muted-foreground shrink-0">
              {formatDate(exp.start)} — {exp.end ? formatDate(exp.end) : 'Present'}
            </span>
          </div>
          <p class="text-sm text-muted-foreground mt-0.5">
            {exp.company}{exp.location ? ` · ${exp.location}` : ''}
          </p>
          {/* annotations not rendered in MVP — see docs/ARCHITECTURE.md */}
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{exp.description}</p>
          {exp.highlights.length > 0 && (
            <ul class="mt-2 space-y-1.5">
              {exp.highlights.map(h => (
                <li class="flex gap-2 items-start text-sm">
                  <span class="text-primary shrink-0 mt-0.5" aria-hidden="true">–</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-base font-semibold uppercase tracking-wide text-muted-foreground border-b border-border pb-1 mb-5">
      Education
    </h2>
    <div class="space-y-4">
      {resume.education.map(edu => (
        <div>
          <div class="flex justify-between items-baseline gap-4">
            <h3 class="font-medium">{edu.institution}</h3>
            <span class="font-mono text-sm text-muted-foreground shrink-0">
              {formatDate(edu.start)} — {edu.end ? formatDate(edu.end) : 'Present'}
            </span>
          </div>
          <p class="text-sm text-muted-foreground mt-0.5">
            {edu.degree}{edu.field ? ` · ${edu.field}` : ''}
          </p>
          {edu.description && (
            <p class="mt-1 text-sm text-muted-foreground">{edu.description}</p>
          )}
        </div>
      ))}
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="mt-10">
      <h2 class="text-base font-semibold uppercase tracking-wide text-muted-foreground border-b border-border pb-1 mb-5">
        Projects
      </h2>
      <div class="space-y-8">
        {featuredProjects.map(project => {
          const hasDetailPage = Boolean(project.body && project.body.trim().length > 0);
          const slug = idToSlug(project.id);
          return (
            <div>
              <div class="flex justify-between items-baseline gap-4">
                <h3 class="font-medium">{project.data.name}</h3>
                {project.data.start && (
                  <span class="font-mono text-sm text-muted-foreground shrink-0">
                    {formatDate(project.data.start)} — {project.data.end ? formatDate(project.data.end) : 'Present'}
                  </span>
                )}
              </div>
              {(hasDetailPage || project.data.liveUrl || project.data.repoUrl) && (
                <div class="flex flex-wrap gap-x-4 gap-y-1 font-mono text-sm text-muted-foreground mt-0.5">
                  {project.data.repoUrl && (
                    <IconLink href={project.data.repoUrl} Icon={GitHubIcon} iconSize={14} label="Source Code" external />
                  )}
                  {project.data.liveUrl && (
                    <IconLink href={project.data.liveUrl} Icon={GlobeIcon} iconSize={14} label="Live Website" external />
                  )}
                  {hasDetailPage && (
                    <IconLink href={`/projects/${slug}`} Icon={ProjectIcon} iconSize={14} label="Details" />
                  )}
                </div>
              )}
              {project.data.tags.length > 0 && (
                <p class="font-mono text-sm text-muted-foreground mt-1">{project.data.tags.join(', ')}</p>
              )}
              {project.data.resumeSummary && (
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{project.data.resumeSummary}</p>
              )}
              {project.data.resumeHighlights && project.data.resumeHighlights.length > 0 && (
                <ul class="mt-2 space-y-1.5">
                  {project.data.resumeHighlights.map(h => (
                    <li class="flex gap-2 items-start text-sm">
                      <span class="text-primary shrink-0 mt-0.5" aria-hidden="true">–</span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          );
        })}
      </div>
    </section>
  )}

  <section class="mt-10">
    <h2 class="text-base font-semibold uppercase tracking-wide text-muted-foreground border-b border-border pb-1 mb-5">
      Skills
    </h2>
    <div class="space-y-3">
      {resume.skills.categories.map(cat => (
        <div class="flex gap-4 text-sm">
          <span class="font-mono text-muted-foreground w-28 shrink-0">{cat.name}</span>
          <span>{cat.items.join(', ')}</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
