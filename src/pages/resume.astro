---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const resumeEntries = await getCollection('resume');
const resumeEntry = resumeEntries[0];
if (!resumeEntry) throw new Error('src/content/resume/main.yaml not found');
const resume = resumeEntry.data;

function formatDate(ym: string): string {
  const [year, month] = ym.split('-');
  return new Date(Number(year), Number(month) - 1).toLocaleDateString('en-US', {
    month: 'short',
    year: 'numeric',
  });
}
---

<BaseLayout title={`Resume — ${resume.basics.name}`} description="Professional resume">
  <div class="space-y-1">
    <h1 class="text-2xl font-bold">{resume.basics.name}</h1>
    <p class="text-gray-600">{resume.basics.title}</p>
    {resume.basics.location && (
      <p class="text-sm text-gray-500">{resume.basics.location}</p>
    )}
  </div>

  {resume.basics.summary && (
    <p class="mt-4 text-gray-700 max-w-prose leading-relaxed">{resume.basics.summary}</p>
  )}

  <section class="mt-10">
    <h2 class="text-base font-semibold uppercase tracking-wide text-gray-500 border-b border-gray-100 pb-1 mb-5">
      Experience
    </h2>
    <div class="space-y-8">
      {resume.experience.map(exp => (
        <div>
          <div class="flex justify-between items-baseline gap-4">
            <h3 class="font-medium">{exp.role}</h3>
            <span class="text-sm text-gray-500 shrink-0">
              {formatDate(exp.start)} — {exp.end ? formatDate(exp.end) : 'Present'}
            </span>
          </div>
          <p class="text-sm text-gray-600 mt-0.5">
            {exp.company}{exp.location ? ` · ${exp.location}` : ''}
          </p>
          {/* annotations not rendered in MVP — see docs/ARCHITECTURE.md */}
          <p class="mt-2 text-sm text-gray-700 leading-relaxed">{exp.description}</p>
          {exp.highlights.length > 0 && (
            <ul class="mt-2 space-y-1 list-disc list-inside">
              {exp.highlights.map(h => (
                <li class="text-sm text-gray-700">{h}</li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-base font-semibold uppercase tracking-wide text-gray-500 border-b border-gray-100 pb-1 mb-5">
      Education
    </h2>
    <div class="space-y-4">
      {resume.education.map(edu => (
        <div>
          <div class="flex justify-between items-baseline gap-4">
            <h3 class="font-medium">{edu.institution}</h3>
            <span class="text-sm text-gray-500 shrink-0">
              {formatDate(edu.start)} — {edu.end ? formatDate(edu.end) : 'Present'}
            </span>
          </div>
          <p class="text-sm text-gray-600 mt-0.5">
            {edu.degree}{edu.field ? ` · ${edu.field}` : ''}
          </p>
          {edu.description && (
            <p class="mt-1 text-sm text-gray-700">{edu.description}</p>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-base font-semibold uppercase tracking-wide text-gray-500 border-b border-gray-100 pb-1 mb-5">
      Skills
    </h2>
    <div class="space-y-3">
      {resume.skills.categories.map(cat => (
        <div class="flex gap-4 text-sm">
          <span class="text-gray-500 w-28 shrink-0">{cat.name}</span>
          <span class="text-gray-700">{cat.items.join(', ')}</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
