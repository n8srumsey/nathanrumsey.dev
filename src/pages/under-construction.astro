<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Under Construction</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: hsl(207 35% 8%);
        background-image: radial-gradient(circle, hsl(162 68% 70% / 0.05) 1px, transparent 1px);
        background-size: 28px 28px;
        color: hsl(210 20% 91%);
        font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
        padding: 2rem;
      }

      .container {
        max-width: 480px;
        text-align: center;
      }

      .domain {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        color: hsl(215 15% 68%);
        margin-bottom: 2rem;
      }

      h1 {
        font-size: clamp(1.5rem, 5vw, 2.25rem);
        font-weight: 600;
        line-height: 1.2;
        margin-bottom: 1rem;
      }

      p {
        font-size: 1rem;
        line-height: 1.6;
        color: hsl(215 15% 68%);
        margin-bottom: 2rem;
      }

      a {
        color: hsl(210 20% 91%);
        text-underline-offset: 3px;
        text-decoration-color: hsl(215 15% 26%);
        transition: color 150ms;
      }

      a:hover {
        color: hsl(162 68% 44%);
      }
    </style>
  </head>
  <body>
    <main class="container">
      <p class="domain">nathanrumsey.dev</p>
      <h1>Under Construction</h1>
      <p>Something new is on the way. Check back soon.</p>
      <p>
        In the meantime, reach me at
        <a href="mailto:nathan@nathanrumsey.dev">nathan@nathanrumsey.dev</a>
      </p>
    </main>
  </body>
</html>
