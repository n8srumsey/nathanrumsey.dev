{
  "permissions": {
    "allow": [
      "Write(.claude/NOTES.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash.py\""
          }
        ]
      }
    ]
  }
}
